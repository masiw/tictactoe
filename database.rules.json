{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      ".read": true,
      "$gameId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.val() === null || newData.hasChildren(['state', 'p1', 'turn', 'createdAt', 'lastMoveAt'])",
        "state": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished')"
        },
        "turn": {
          ".validate": "newData.isString() && (newData.val() === 'X' || newData.val() === 'O')"
        },
        "winner": {
          ".validate": "newData.val() === 'X' || newData.val() === 'O' || newData.val() === 'draw'"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "lastMoveAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "previousMove": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 8"
        },
        "previousMoveRevealed": {
          ".validate": "newData.isBoolean()"
        },
        "p1": {
          ".validate": "newData.hasChild('id')",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200"
          },
          "$other": { ".validate": false }
        },
        "p2": {
          ".validate": "newData.hasChild('id')",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200"
          },
          "$other": { ".validate": false }
        },
        "board": {
          "$i": {
            ".validate": "$i.matches(/^[0-8]$/) && newData.isString() && (newData.val() === 'X' || newData.val() === 'O')"
          }
        },
        "$other": { ".validate": false }
      }
    },
    "dominoes": {
      ".read": true,
      "$gameId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.val() === null || newData.hasChildren(['state', 'p1', 'turn', 'createdAt', 'lastMoveAt'])",
        "state": {
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'playing' || newData.val() === 'finished')"
        },
        "turn": {
          ".validate": "newData.isString() && (newData.val() === 'p1' || newData.val() === 'p2')"
        },
        "winner": {
          ".validate": "newData.val() === 'p1' || newData.val() === 'p2' || newData.val() === 'draw'"
        },
        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "lastMoveAt": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "leftEnd": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 6"
        },
        "rightEnd": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 6"
        },
        "board": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "consecutivePasses": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 2"
        },
        "p1": {
          ".validate": "newData.hasChild('id')",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200"
          },
          "hand": {
            ".validate": "newData.isString() && newData.val().length <= 200"
          },
          "$other": { ".validate": false }
        },
        "p2": {
          ".validate": "newData.hasChild('id')",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 200"
          },
          "hand": {
            ".validate": "newData.isString() && newData.val().length <= 200"
          },
          "$other": { ".validate": false }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
